# Supabase (get these from your Supabase project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role (server-side only — NEVER expose in frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — Individual subscriptions
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...          # Individual Pro plan ($5.99/mo)

# Stripe — Institutional (per-seat annual)
STRIPE_ORG_PRICE_ID=price_...      # Org seat price (annual, per seat)

# App URL (used for Stripe redirect and invite emails)
APP_URL=https://your-app.vercel.app

# ─── Google SSO (optional but recommended for schools) ───────────────────────
# Enable in: Supabase Dashboard → Authentication → Providers → Google
# No env vars needed here — configured directly in Supabase.
# In Supabase, set Authorized redirect URI to:
#   https://your-project.supabase.co/auth/v1/callback
# Then add your Google OAuth Client ID + Secret from console.cloud.google.com
#
# For Clever / ClassLink SSO, contact us for enterprise setup.
